# MySQL 접속 정보 (application.yml 의 spring.datasource 에서 참조)
DB_USERNAME=root
DB_PASSWORD=

# JWT 서명 키 (최소 32자 이상 랜덤 문자열 권장)
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-32-chars

# 이메일 인증 사용 시 (application.yml mail.provider: smtp 로 바꿀 때)
MAIL_USERNAME=
MAIL_PASSWORD=

# 휴대폰 인증 사용 시 (application.yml sms.provider: solapi 로 바꿀 때)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# 알리고를 쓸 경우 (application.yml sms.provider: aligo 로 바꿀 때)
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=
