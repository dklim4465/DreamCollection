# Database
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-32-chars

# Mail
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password

# SMS
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_SENDER=01000000000

# Kakao OAuth
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback/kakao

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Toss Payments
TOSS_SECRET_KEY=test_sk_dummy_for_local_dev
