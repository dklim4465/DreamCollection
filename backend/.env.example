# ════════════════════════════════════════════════════════════════
# 백엔드 환경변수 — 이 파일을 복사해서 반드시 backend/.env 로 저장하세요
# (프로젝트 루트나 frontend 폴더가 아니라 backend 폴더 안이어야 합니다!)
#
# application.properties의 spring.config.import=optional:file:./.env[.properties]
# 가 "현재 작업 디렉터리 기준 ./.env"를 읽기 때문에, IntelliJ/Gradle에서
# 백엔드를 실행할 때 작업 디렉터리가 보통 backend/ 이므로 여기에 둬야 합니다.
# ════════════════════════════════════════════════════════════════

# --- 데이터베이스 ---
DB_USERNAME=root
DB_PASSWORD=1234

# --- JWT 서명 키 (최소 32자 이상 랜덤 문자열 권장) ---
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-32-chars

# --- 이메일 발송 (mail.provider: smtp일 때만 필요) ---
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# --- 휴대폰 인증 (Solapi) ---
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_SENDER=01000000000

# --- 카카오 로그인 ---
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback/kakao

# --- Toss Payments (카드 등록/결제) ---
# ⚠ SECRET_KEY와 CLIENT_KEY는 반드시 같은 Toss Payments 테스트 상점의 키 쌍이어야
#   합니다. 한쪽만 실제 값이고 다른 쪽이 더미면 결제 연동이 실패합니다.
#   https://developers.tosspayments.com 에서 테스트 상점 키를 발급받으세요.
TOSS_SECRET_KEY=test_sk_dummy_for_local_dev
TOSS_CLIENT_KEY=test_ck_dummy_for_local_dev

# --- SerpAPI (항공권/실시간 검색) ---
SERPAPI_API_KEY=your_serpapi_api_key

# --- 홈페이지 AI 챗봇 (Gemini) ---
# ⚠ 코드가 실제로 읽는 환경변수 이름은 GEMINI_API_KEY 입니다.
#   (GCP_API_KEY 라고 잘못 알려진 적이 있는데 그 이름으론 절대 인식되지 않습니다 —
#    GeminiChatClient.java의 @Value("${gemini.api-key:}") 참고)
#   https://aistudio.google.com 에서 발급받으세요.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
